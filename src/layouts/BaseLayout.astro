---
import '@fontsource-variable/inter';
import '@fontsource-variable/cormorant-garamond';
import '../styles/reset.css';
import '../styles/tokens.css';
import '../styles/global.css';

import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Per-locale href overrides for hreflang (pass when page slugs differ between locales). */
  alternates?: Partial<Record<Lang, string>>;
}

const {
  title,
  description,
  canonical,
  ogImage,
  noindex = false,
  alternates,
} = Astro.props;

const lang        = (Astro.currentLocale ?? 'it') as Lang;
const canonicalUrl = canonical ?? Astro.url.href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO
      title={title}
      description={description}
      canonical={canonicalUrl}
      lang={lang}
      currentPath={Astro.url.pathname}
      ogImage={ogImage}
      noindex={noindex}
      alternates={alternates}
    />
    <!-- TODO PR-9 (full): Iubenda Cookie Solution
         Uncomment after Gennaro adds PUBLIC_IUBENDA_POLICY_ID and
         PUBLIC_IUBENDA_COOKIE_POLICY_ID to the Vercel dashboard (spec §8.1).
         Replace SITE_ID with the numeric siteId from the Iubenda dashboard.

    <script>
      var _iub = _iub || [];
      _iub.csConfiguration = {
        "askConsentAtCookiePolicyUpdate": true,
        "floatingPreferencesButtonDisplay": false,
        "perPurposeConsent": true,
        "siteId": SITE_ID,
        "cookiePolicyId": import.meta.env.PUBLIC_IUBENDA_COOKIE_POLICY_ID,
        "lang": "{lang}",
        "storage": { "useSiteId": true }
      };
    </script>
    <script src={`https://cs.iubenda.com/autoblocking/${SITE_ID}.js`}></script>
    <script src="//cdn.iubenda.com/cs/iubenda_cs.js" charset="UTF-8" async></script>
    -->
    <slot name="head" />
  </head>
  <body>
    <div id="gp-splash" style="display:none">
      <p class="gp-splash-title">Giada Palace</p>
      <p class="gp-splash-sub">Rooms &amp; Apartments · Lucca</p>
    </div>
    <script>
      (function () {
        if (!sessionStorage.getItem('gp_splash')) {
          var el = document.getElementById('gp-splash');
          if (el) {
            var splash = el;
            splash.style.display = 'flex';
            sessionStorage.setItem('gp_splash', '1');
            splash.addEventListener('animationend', function () { splash.remove(); }, { once: true });
          }
        }
      })();
    </script>
    <Header lang={lang} currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>

<style>
  #gp-splash {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--gp-cream);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    animation: gp-splash-fade 1.7s ease forwards;
    pointer-events: none;
  }

  @keyframes gp-splash-fade {
    0%    { opacity: 0; }
    23.5% { opacity: 1; }
    70.6% { opacity: 1; }
    100%  { opacity: 0; }
  }

  .gp-splash-title {
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 400;
    color: var(--gp-navy);
    margin: 0;
    line-height: 1;
  }

  .gp-splash-sub {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.2em;
    color: var(--gp-muted);
    text-transform: uppercase;
    margin: 0;
  }
</style>
