---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';

const email = import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'giadapalacerooms@gmail.com';
---

<BaseLayout
  title="Cookie Policy | Giada Palace"
  description="Giada Palace cookie policy — document coming soon."
  alternates={{ it: '/cookie-policy' }}
>
  <!-- TODO PR-9 (full): replace with Iubenda EN cookie policy iframe embed. -->
  <section class="legal-section">
    <div class="container legal-inner">
      <span class="eyebrow">— Cookie Policy —</span>
      <h1 class="legal-h1">Cookie Policy</h1>
      <div class="legal-placeholder">
        <p>
          The Cookie Policy document is being prepared and will be published shortly.
        </p>
        <p>
          For any questions regarding the use of cookies on this site,
          contact us at{' '}
          <a href={`mailto:${email}`}>{email}</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal-section {
    padding-block: var(--space-20);
    background: var(--gp-cream);
    min-height: 60vh;
  }

  .legal-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: var(--max-width-reading);
  }

  .legal-h1 {
    font-family: var(--font-serif);
    font-size: var(--text-2xl);
    font-weight: var(--weight-regular);
    color: var(--gp-ink);
    margin: 0;
  }

  .legal-placeholder {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-8);
    background: var(--gp-white);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--radius-lg);
  }

  .legal-placeholder p {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--gp-muted);
    margin: 0;
  }

  .legal-placeholder a {
    color: var(--gp-navy);
    text-underline-offset: 2px;
  }
</style>
