---
export const prerender = false;
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm';
import type { ContactFormLabels } from '../components/ContactForm';
import { useTranslations } from '../i18n/utils';

const lang = 'it';
const t = useTranslations(lang);

// Read URL params server-side
const params = Astro.url.searchParams;
const fromParam  = params.get('from')   ?? '';
const toParam    = params.get('to')     ?? '';
const guestsParam = params.get('guests') ?? '';
const unitParam  = params.get('unit')   ?? '';

const hasParams = Boolean(fromParam || toParam || guestsParam);

// Build unit list for the dropdown (all 11 units, IT names)
const allUnits = (await getCollection('units')).sort((a, b) => a.data.order - b.data.order);
const unitOptions = allUnits.map((u) => ({
  slug: u.slug,
  name: u.data.name.it,
}));

// WhatsApp link — pre-filled if params present
const waNumber = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '393513295448';
const unitName = unitOptions.find((u) => u.slug === unitParam)?.name ?? '';
const waMessage = unitParam && fromParam && toParam
  ? `Ciao, vorrei informazioni per ${unitName} dal ${fromParam} al ${toParam} per ${guestsParam} ospiti.`
  : fromParam && toParam
    ? `Ciao, vorrei informazioni per il periodo ${fromParam} — ${toParam} per ${guestsParam} ospiti.`
    : `Ciao, vorrei informazioni su Giada Palace.`;
const waLink = `https://wa.me/${waNumber}?text=${encodeURIComponent(waMessage)}`;

const phoneDisplay = import.meta.env.PUBLIC_PHONE_DISPLAY  ?? '+39 351 329 5448';
const phoneHref    = import.meta.env.PUBLIC_PHONE_NUMBER   ?? '+393513295448';
const contactEmail = import.meta.env.PUBLIC_CONTACT_EMAIL  ?? 'giadapalacerooms@gmail.com';
const accessKey    = import.meta.env.PUBLIC_WEB3FORMS_KEY  ?? '';

const labels: ContactFormLabels = {
  name:               t('contact.form.name'),
  email:              t('contact.form.email'),
  phone:              t('contact.form.phone'),
  unit:               t('contact.form.unit'),
  unitPlaceholder:    t('contact.form.unit_placeholder'),
  checkin:            t('contact.form.checkin'),
  checkout:           t('contact.form.checkout'),
  guests:             t('contact.form.guests'),
  message:            t('contact.form.message'),
  messagePlaceholder: t('contact.form.message_placeholder'),
  gdpr:               t('contact.form.gdpr'),
  gdprLink:           t('contact.form.gdpr_link'),
  submit:             t('contact.form.submit'),
  submitting:         t('contact.form.submitting'),
  success:            t('contact.form.success'),
  error:              t('contact.form.error'),
};
---

<BaseLayout
  title="Contatti — Prenota il tuo soggiorno | Giada Palace"
  description="Contattaci per prenotare un appartamento o una camera al Giada Palace, Lucca. Rispondiamo entro 24 ore via telefono, WhatsApp o email."
  alternates={{ en: '/en/contact' }}
>

  <!-- Hero-lite -->
  <section class="contact-hero">
    <div class="container contact-hero-inner">
      <span class="eyebrow contact-eyebrow">— Contatti —</span>
      <h1 class="contact-h1">{t('contact.h1')}</h1>
      <p class="contact-subtitle">{t('contact.subtitle')}</p>
    </div>
  </section>

  <!-- Blue info strip (params present) -->
  {hasParams && (
    <div class="contact-strip" role="note" aria-label="Periodo preselezionato">
      <div class="container contact-strip-inner">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="contact-strip-icon">
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 8v4M12 16h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <span class="contact-strip-text">
          {t('contact.strip.prefix')} <strong>{fromParam} — {toParam}</strong>
          {guestsParam && <> · <strong>{guestsParam} {t('contact.strip.guests')}</strong></>}
          {unitName && <> · <strong>{unitName}</strong></>}
        </span>
      </div>
    </div>
  )}

  <!-- Three contact cards -->
  <section class="contact-cards-section">
    <div class="container contact-cards-grid">

      <!-- Phone -->
      <a href={`tel:${phoneHref}`} class="contact-card contact-card--phone">
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.5 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.41 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="contact-card-body">
          <span class="contact-card-label">{t('contact.phone.label')}</span>
          <span class="contact-card-value">{phoneDisplay}</span>
          <span class="contact-card-note">{t('contact.phone.hours')}</span>
        </div>
        <div class="contact-card-arrow" aria-hidden="true">→</div>
      </a>

      <!-- WhatsApp -->
      <a href={waLink} target="_blank" rel="noopener noreferrer" class="contact-card contact-card--whatsapp">
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
          </svg>
        </div>
        <div class="contact-card-body">
          <span class="contact-card-label">{t('contact.whatsapp.label')}</span>
          <span class="contact-card-value">{t('contact.whatsapp.cta')}</span>
          <span class="contact-card-note">{t('contact.whatsapp.note')}</span>
        </div>
        <div class="contact-card-arrow" aria-hidden="true">→</div>
      </a>

      <!-- Email -->
      <a href={`mailto:${contactEmail}`} class="contact-card contact-card--email">
        <div class="contact-card-icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="4" width="20" height="16" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M2 7l10 7 10-7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="contact-card-body">
          <span class="contact-card-label">{t('contact.email.label')}</span>
          <span class="contact-card-value contact-card-value--email">{contactEmail}</span>
          <span class="contact-card-note">{t('contact.email.note')}</span>
        </div>
        <div class="contact-card-arrow" aria-hidden="true">→</div>
      </a>

    </div>
  </section>

  <!-- Divider + Form -->
  <section class="contact-form-section">
    <div class="container contact-form-inner">
      <div class="contact-divider-row" aria-hidden="true">
        <span class="contact-divider-line"></span>
        <span class="contact-divider-text">{t('contact.divider')}</span>
        <span class="contact-divider-line"></span>
      </div>

      <div class="contact-form-wrap">
        <ContactForm
          client:load
          accessKey={accessKey}
          units={unitOptions}
          defaultUnit={unitParam}
          defaultFrom={fromParam}
          defaultTo={toParam}
          defaultGuests={guestsParam}
          privacyHref="/privacy"
          contactEmail={contactEmail}
          labels={labels}
        />
      </div>
    </div>
  </section>

  <!-- Map placeholder
       TODO PR-9 (full): once the Iubenda CS script is live, replace the
       static placeholder div below with a consent-gated Google Maps iframe:
         - If _iub.cs.api.isConsentGiven('maps') → render <iframe> embed
         - Else → show this placeholder + an "accetta i cookie" button that
           calls _iub.cs.api.openPreferences() to surface the consent panel
       Google Maps embed URL: https://maps.google.com/maps?q={{LAT}},{{LON}}&z=15&output=embed
       (LAT/LON from spec §2 — provide when Gennaro confirms the street address)
  -->
  <section class="contact-map-section" aria-labelledby="map-heading">
    <div class="container">
      <h2 id="map-heading" class="contact-map-heading">Come raggiungerci</h2>
    </div>
    <div class="contact-map-placeholder" role="img" aria-label="Mappa interattiva — accetta i cookie per visualizzarla">
      <div class="contact-map-inner">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="contact-map-icon">
          <circle cx="12" cy="10" r="3" stroke="currentColor" stroke-width="1.5"/>
          <path d="M12 2C7.58 2 4 5.58 4 10c0 5.25 8 12 8 12s8-6.75 8-12c0-4.42-3.58-8-8-8Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
        </svg>
        <p class="contact-map-text">{t('contact.map.placeholder')}</p>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero-lite */
  .contact-hero {
    background: var(--gp-cream);
    padding-block: var(--space-16);
    border-bottom: 1px solid var(--gp-border-soft);
  }

  .contact-hero-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 640px;
  }

  .contact-eyebrow { color: var(--gp-muted); }

  .contact-h1 {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    color: var(--gp-ink);
    margin: 0;
  }

  .contact-subtitle {
    font-size: var(--text-md);
    color: var(--gp-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Info strip */
  .contact-strip {
    background: #EFF6FF;
    border-bottom: 1px solid #BFDBFE;
  }

  .contact-strip-inner {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding-block: var(--space-3);
  }

  .contact-strip-icon { color: #2563EB; flex-shrink: 0; }

  .contact-strip-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: #1E40AF;
    line-height: 1.5;
  }

  .contact-strip-text strong { font-weight: var(--weight-medium); }

  /* Contact cards */
  .contact-cards-section {
    padding-block: var(--space-12);
    background: var(--gp-white);
  }

  .contact-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-5);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--gp-cream);
    border: 1px solid var(--gp-border-soft);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
  }

  .contact-card:hover {
    border-color: var(--gp-border);
    box-shadow: 0 2px 12px rgba(30, 45, 61, 0.08);
    background: var(--gp-white);
  }

  .contact-card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-card--phone   .contact-card-icon { background: #EEF2FF; color: #4338CA; }
  .contact-card--whatsapp .contact-card-icon { background: #F0FDF4; color: #16A34A; }
  .contact-card--email   .contact-card-icon { background: #FFF7ED; color: #C2410C; }

  .contact-card-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    min-width: 0;
  }

  .contact-card-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gp-muted);
  }

  .contact-card-value {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--gp-ink);
    line-height: 1.2;
  }

  .contact-card-value--email {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .contact-card-note {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--gp-muted);
  }

  .contact-card-arrow {
    font-size: var(--text-lg);
    color: var(--gp-muted);
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }

  .contact-card:hover .contact-card-arrow { transform: translateX(3px); }

  /* Form section */
  .contact-form-section {
    padding-block: var(--space-16);
    background: var(--gp-cream);
  }

  .contact-form-inner {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  .contact-divider-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .contact-divider-line {
    flex: 1;
    height: 1px;
    background: var(--gp-border);
  }

  .contact-divider-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--gp-muted);
    white-space: nowrap;
  }

  /* Map */
  .contact-map-section {
    padding-top: var(--space-16);
    background: var(--gp-white);
  }

  .contact-map-heading {
    font-size: var(--text-xl);
    color: var(--gp-ink);
    margin-bottom: var(--space-8);
  }

  .contact-map-placeholder {
    width: 100%;
    height: 360px;
    background: var(--gp-cream);
    border-top: 1px solid var(--gp-border-soft);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-map-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-width: 320px;
    text-align: center;
  }

  .contact-map-icon { color: var(--gp-muted); }

  .contact-map-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--gp-muted);
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .contact-cards-grid { grid-template-columns: 1fr; gap: var(--space-3); }
    .contact-card-arrow { display: none; }
  }

  @media (max-width: 767px) {
    .contact-h1 { font-size: var(--text-2xl); }
    .contact-map-placeholder { height: 240px; }
    .contact-form-inner { max-width: 100%; }
  }
</style>
