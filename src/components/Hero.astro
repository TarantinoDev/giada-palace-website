---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/pool/hero-sunset.jpg';
import AvailabilityForm from './AvailabilityForm.astro';
---

<section class="hero" aria-label="Benvenuti a Giada Palace">
  <Image
    src={heroImage}
    alt=""
    aria-hidden="true"
    class="hero-bg"
    widths={[768, 1280, 1920, 2400]}
    sizes="100vw"
    loading="eager"
    fetchpriority="high"
  />
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-content container">
    <span class="eyebrow hero-eyebrow">Lucca — a 15 minuti a piedi dalle mura</span>
    <h1 class="hero-h1">
      La tua casa in Toscana,<br>
      <em>con la piscina sotto casa</em>
    </h1>
    <p class="hero-subtitle">
      Appartamenti e camere a due passi da Lucca, con piscina estiva,
      parcheggio privato e navetta urbana a 50 mt.
    </p>
    <AvailabilityForm />
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 60%;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(30, 45, 61, 0.82) 0%,
      rgba(30, 45, 61, 0.58) 48%,
      rgba(30, 45, 61, 0.18) 80%,
      transparent 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 640px;
    padding-block: var(--space-20);
  }

  .hero-eyebrow {
    color: var(--gp-coral-light);
    margin-bottom: var(--space-4);
  }

  .hero-h1 {
    font-family: var(--font-serif);
    font-size: var(--text-3xl);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    color: var(--gp-white);
    margin-bottom: var(--space-5);
  }

  .hero-h1 em {
    font-style: italic;
    color: var(--gp-coral-light);
  }

  .hero-subtitle {
    font-size: var(--text-md);
    line-height: var(--leading-snug);
    color: rgba(255, 255, 255, 0.85);
    max-width: 52ch;
  }

  @media (max-width: 767px) {
    .hero {
      align-items: flex-end;
    }

    .hero-overlay {
      background: linear-gradient(
        to top,
        rgba(30, 45, 61, 0.88) 0%,
        rgba(30, 45, 61, 0.55) 55%,
        rgba(30, 45, 61, 0.15) 100%
      );
    }

    .hero-content {
      max-width: 100%;
      padding-bottom: var(--space-12);
    }

    .hero-h1 {
      font-size: var(--text-2xl);
    }
  }
</style>
