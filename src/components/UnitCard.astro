---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  unit: CollectionEntry<'units'>;
  lang: Lang;
  detailBaseHref: string;
}

const { unit, lang, detailBaseHref } = Astro.props;
const { slug, data } = unit;
const t = useTranslations(lang);

const name        = data.name[lang] ?? data.name.it;
const shortDesc   = (data.shortDescription[lang] ?? data.shortDescription.it);
const href        = `${detailBaseHref}/${slug}`;
const guestsLabel = `${data.maxGuests} ${t('unit.guests_label')}`;
---

<article class:list={['unit-card', data.isDraft && 'unit-card--draft']}>
  <div class="unit-card-img-wrap">
    <Image
      src={data.heroImage}
      alt={`${name} — Giada Palace`}
      widths={[400, 600, 800]}
      sizes="(max-width: 599px) 100vw, (max-width: 1023px) 50vw, 33vw"
      class="unit-card-img"
      loading="lazy"
    />
    {data.isDraft && (
      <span class="unit-card-badge">{t('unit.draft.badge')}</span>
    )}
  </div>
  <div class="unit-card-body">
    <p class="unit-card-guests">{guestsLabel}</p>
    <h3 class="unit-card-name">
      <a href={href} class="unit-card-link">{name}</a>
    </h3>
    <p class="unit-card-desc">{shortDesc}</p>
    <span class="unit-card-cta" aria-hidden="true">
      {t('unit.cta_availability')} →
    </span>
  </div>
</article>

<style>
  .unit-card {
    position: relative;
    background: var(--gp-white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--gp-border-soft);
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s ease;
  }

  .unit-card:hover {
    box-shadow: 0 8px 32px rgba(30, 45, 61, 0.1);
  }

  .unit-card--draft {
    opacity: 0.82;
  }

  .unit-card--draft:hover {
    box-shadow: 0 4px 16px rgba(30, 45, 61, 0.07);
  }

  .unit-card-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .unit-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .unit-card:hover .unit-card-img {
    transform: scale(1.03);
  }

  .unit-card--draft:hover .unit-card-img {
    transform: none;
  }

  .unit-card-badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    padding: var(--space-1) var(--space-3);
    background: var(--gp-navy);
    color: var(--gp-white);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: var(--radius-sm);
  }

  .unit-card-body {
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex: 1;
  }

  .unit-card-guests {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gp-coral);
    margin: 0;
  }

  .unit-card-name {
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--gp-ink);
    margin: 0;
  }

  /* Stretched-link: the <a> covers the entire card */
  .unit-card-link {
    color: inherit;
    text-decoration: none;
  }

  .unit-card-link::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .unit-card-desc {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--gp-muted);
    flex: 1;
    margin: 0;
  }

  .unit-card-cta {
    display: inline-block;
    margin-top: var(--space-2);
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--gp-navy);
  }

  .unit-card--draft .unit-card-cta {
    color: var(--gp-muted);
  }
</style>
