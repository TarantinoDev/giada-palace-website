---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  images: ImageMetadata[];
  slug: string;
  unitName: string;
  lang: Lang;
}

const { images, slug, unitName, lang } = Astro.props;
const t = useTranslations(lang);
const hasMultiple = images.length > 1;
const anchorId = `${slug}-gallery`;
---

<div class="unit-gallery">
  {hasMultiple ? (
    <>
      {/* Invisible anchor so close button scrolls here, not to page top */}
      <span id={anchorId} class="gallery-anchor" aria-hidden="true"></span>

      <div class="gallery-thumbs" role="list">
        {images.map((img, i) => (
          <a
            href={`#${slug}-img-${i}`}
            class="gallery-thumb-link"
            role="listitem"
            aria-label={`${t('gallery.open')} ${i + 1}`}
          >
            <Image
              src={img}
              alt={`${unitName} — foto ${i + 1}`}
              widths={[300, 600]}
              sizes="(max-width: 767px) 45vw, 200px"
              class="gallery-thumb-img"
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          </a>
        ))}
      </div>

      {images.map((img, i) => (
        <div id={`${slug}-img-${i}`} class="lightbox" role="dialog" aria-modal="true" aria-label={`${unitName} — foto ${i + 1}`}>
          <a href={`#${anchorId}`} class="lightbox-close" aria-label={t('gallery.close')}>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 4L16 16M16 4L4 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </a>
          <a href={`#${anchorId}`} class="lightbox-backdrop" aria-label={t('gallery.close')} tabindex="-1"></a>
          <div class="lightbox-content">
            <Image
              src={img}
              alt={`${unitName} — foto ${i + 1}`}
              widths={[800, 1200, 1600]}
              sizes="(max-width: 767px) 100vw, 90vw"
              class="lightbox-img"
              loading="lazy"
            />
          </div>
          <a
            href={`#${slug}-img-${i === 0 ? images.length - 1 : i - 1}`}
            class="lightbox-prev"
            aria-label={t('gallery.prev')}
          >‹</a>
          <a
            href={`#${slug}-img-${(i + 1) % images.length}`}
            class="lightbox-next"
            aria-label={t('gallery.next')}
          >›</a>
        </div>
      ))}
    </>
  ) : (
    <div class="gallery-single">
      <Image
        src={images[0]}
        alt={`${unitName} — Giada Palace`}
        widths={[600, 900, 1200]}
        sizes="(max-width: 767px) 100vw, (max-width: 1200px) 80vw, 1000px"
        class="gallery-single-img"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  )}
</div>

<style>
  .unit-gallery {
    position: relative;
  }

  .gallery-anchor {
    display: block;
    height: 0;
    overflow: hidden;
  }

  /* Single image */
  .gallery-single {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .gallery-single-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Thumbnail strip */
  .gallery-thumbs {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .gallery-thumb-link {
    display: block;
    width: 200px;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 2px solid transparent;
    transition: border-color 0.15s ease;
    flex-shrink: 0;
  }

  .gallery-thumb-link:first-child {
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
  }

  .gallery-thumb-link:hover {
    border-color: var(--gp-coral);
  }

  .gallery-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-thumb-link:hover .gallery-thumb-img {
    transform: scale(1.04);
  }

  /* Lightbox */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
    align-items: center;
    justify-content: center;
  }

  .lightbox:target {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(15, 20, 30, 0.93);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    max-width: min(92vw, 1100px);
    max-height: 90vh;
    display: flex;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--gp-white);
    border-radius: 50%;
    transition: background 0.15s ease;
    text-decoration: none;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(255, 255, 255, 0.12);
    color: var(--gp-white);
    border-radius: 50%;
    font-size: 28px;
    line-height: 1;
    text-decoration: none;
    transition: background 0.15s ease;
  }

  .lightbox-prev { left: var(--space-4); }
  .lightbox-next { right: var(--space-4); }

  .lightbox-prev:hover,
  .lightbox-next:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  @media (max-width: 767px) {
    .gallery-thumb-link {
      width: calc(50% - var(--space-1));
    }

    .gallery-thumb-link:first-child {
      width: 100%;
    }

    .lightbox-prev { left: var(--space-2); }
    .lightbox-next { right: var(--space-2); }
  }
</style>
