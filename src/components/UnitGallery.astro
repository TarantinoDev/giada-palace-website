---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  images: ImageMetadata[];
  slug: string;
  unitName: string;
  lang: Lang;
}

const { images, slug, unitName, lang } = Astro.props;
const t = useTranslations(lang);
const hasMultiple = images.length > 1;

const prevId = (i: number) => `${slug}-s${i === 0 ? images.length - 1 : i - 1}`;
const nextId = (i: number) => `${slug}-s${(i + 1) % images.length}`;

let dynamicCSS = '';
if (hasMultiple) {
  for (let i = 0; i < images.length; i++) {
    dynamicCSS += `#${slug}-s${i}:checked ~ .car-wrap .car-slide:nth-child(${i + 1}) { display: block; }`;
    dynamicCSS += `#${slug}-s${i}:checked ~ .car-wrap .car-prev--${i} { display: flex; }`;
    dynamicCSS += `#${slug}-s${i}:checked ~ .car-wrap .car-next--${i} { display: flex; }`;
    dynamicCSS += `#${slug}-s${i}:checked ~ .car-wrap .car-dot:nth-child(${i + 1}) { opacity: 1; background: var(--gp-navy); }`;
  }
}
---

<div class="unit-gallery">
  {hasMultiple && (
    <>
      {images.map((_, i) => (
        <input
          type="radio"
          name={`${slug}-gallery`}
          id={`${slug}-s${i}`}
          class="car-input"
          checked={i === 0}
          aria-hidden="true"
        />
      ))}

      <div class="car-wrap">
        <div class="car-track">
          {images.map((img, i) => (
            <div class="car-slide">
              <Image
                src={img}
                alt={`${unitName} — foto ${i + 1}`}
                widths={[768, 1200, 1600]}
                sizes="(max-width: 767px) 100vw, (max-width: 1200px) 80vw, 1000px"
                class="car-img"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : undefined}
              />
            </div>
          ))}
        </div>

        {images.map((_, i) => (
          <>
            <label class={`car-arrow car-prev car-prev--${i}`} for={prevId(i)} aria-label={t('gallery.prev')}>‹</label>
            <label class={`car-arrow car-next car-next--${i}`} for={nextId(i)} aria-label={t('gallery.next')}>›</label>
          </>
        ))}

        <div class="car-dots">
          {images.map((_, i) => (
            <label class="car-dot" for={`${slug}-s${i}`} aria-label={String(i + 1)}></label>
          ))}
        </div>
      </div>
    </>
  )}

  {!hasMultiple && (
    <div class="gallery-single">
      <Image
        src={images[0]}
        alt={`${unitName} — Giada Palace`}
        widths={[600, 900, 1200]}
        sizes="(max-width: 767px) 100vw, (max-width: 1200px) 80vw, 1000px"
        class="gallery-single-img"
        loading="eager"
        fetchpriority="high"
      />
    </div>
  )}
</div>

{hasMultiple && <Fragment set:html={`<style>${dynamicCSS}</style>`} />}

<style>
  .unit-gallery { position: relative; }

  .car-input { display: none; }

  /* Single image */
  .gallery-single {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 16 / 9;
  }

  .gallery-single-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Carousel wrapper */
  .car-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--gp-cream);
    border-radius: var(--radius-lg);
  }

  /* Track clips images to rounded corners */
  .car-track {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-radius: inherit;
  }

  .car-slide {
    display: none;
    position: absolute;
    inset: 0;
  }

  .car-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Arrows — hidden by default, shown via dynamic CSS */
  .car-arrow {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.85);
    color: var(--gp-navy);
    border-radius: 50%;
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    user-select: none;
    transition: background 0.15s ease;
  }

  .car-arrow:hover { background: var(--gp-white); }

  .car-prev { left: var(--space-3); }
  .car-next { right: var(--space-3); }

  /* Dots */
  .car-dots {
    position: absolute;
    bottom: var(--space-3);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
    max-width: 90%;
    flex-wrap: wrap;
    justify-content: center;
  }

  .car-dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.5);
    opacity: 0.6;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.15s ease, opacity 0.15s ease;
  }

  .car-dot:hover { opacity: 0.9; }

  @media (max-width: 767px) {
    .car-wrap { aspect-ratio: 4 / 3; }
    .car-arrow { width: 36px; height: 36px; font-size: 20px; }
  }
</style>
