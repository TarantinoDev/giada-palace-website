---
import { Image } from 'astro:assets';
import poolImg from '../assets/images/pool/hero-sunset.jpg';
---

<section class="pool-section">
  <div class="container pool-inner">

    <div class="pool-text">
      <span class="eyebrow">— La piscina —</span>
      <h2>Fresca d'estate,<br>da aprile a ottobre</h2>
      <p>
        Dopo una giornata sulle mura o in ufficio, la piscina all'aperto ti
        aspetta. Area lettini, ombrelloni e giardino attrezzato, riservati
        agli ospiti.
      </p>
      <a href="/la-piscina" class="btn btn-secondary pool-cta">
        Scopri la piscina <span aria-hidden="true">→</span>
      </a>
    </div>

    <div class="pool-img-wrap">
      <Image
        src={poolImg}
        alt="Piscina di Giada Palace al tramonto con area lettini"
        widths={[600, 900, 1200]}
        sizes="(max-width: 767px) 100vw, 50vw"
        class="pool-img"
        loading="lazy"
      />
    </div>

  </div>
</section>

<style>
  .pool-section {
    padding-block: var(--space-20);
    background-color: var(--gp-white);
  }

  .pool-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .pool-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .pool-text .eyebrow {
    margin-bottom: calc(var(--space-3) * -1);
  }

  .pool-text h2 {
    font-size: var(--text-2xl);
    line-height: var(--leading-tight);
  }

  .pool-text p {
    font-size: var(--text-md);
    line-height: var(--leading-normal);
    color: var(--gp-muted);
    max-width: 46ch;
  }

  .pool-cta {
    align-self: flex-start;
  }

  .pool-img-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    aspect-ratio: 4 / 3;
  }

  .pool-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 767px) {
    .pool-inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    /* Image above text on mobile */
    .pool-img-wrap {
      order: -1;
    }

    .pool-text h2 {
      font-size: var(--text-xl);
    }
  }
</style>
