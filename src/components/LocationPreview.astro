---
import { Image } from 'astro:assets';
import facadeImg from '../assets/images/exterior/facade-day.jpg';
---

<section class="location-section" aria-label="Dove siamo">
  <div class="location-img-wrap">
    <Image
      src={facadeImg}
      alt="Facciata esterna di Giada Palace vicino a Lucca, in zona ospedale"
      widths={[768, 1280, 1920]}
      sizes="100vw"
      class="location-img"
      loading="lazy"
    />
    <div class="location-overlay" aria-hidden="true"></div>
  </div>

  <div class="location-content container">
    <span class="eyebrow location-eyebrow">— Dove siamo —</span>
    <h2 class="location-h2">A 15 minuti a piedi<br>dalle mura di Lucca</h2>
    <p class="location-body">
      Giada Palace si trova a pochi minuti da Lucca, in zona ospedale.
      Parcheggio privato, accesso rapido all'autostrada, bus per il centro.
    </p>
    <a href="/lucca" class="btn location-cta">
      Scopri la zona <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  .location-section {
    position: relative;
    min-height: 480px;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .location-img-wrap {
    position: absolute;
    inset: 0;
  }

  .location-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .location-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(30, 45, 61, 0.78) 0%,
      rgba(30, 45, 61, 0.5) 50%,
      rgba(30, 45, 61, 0.15) 100%
    );
  }

  .location-content {
    position: relative;
    z-index: 2;
    max-width: 560px;
    padding-block: var(--space-20);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .location-eyebrow {
    color: var(--gp-coral-light);
    margin-bottom: calc(var(--space-3) * -1);
  }

  .location-h2 {
    font-size: var(--text-2xl);
    color: var(--gp-white);
    line-height: var(--leading-tight);
  }

  .location-body {
    font-size: var(--text-md);
    color: rgba(255, 255, 255, 0.82);
    line-height: var(--leading-normal);
  }

  .location-cta {
    align-self: flex-start;
    background: rgba(255, 255, 255, 0.15);
    color: var(--gp-white);
    border-color: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(4px);
  }

  .location-cta:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: var(--gp-white);
  }

  @media (max-width: 767px) {
    .location-section {
      min-height: 420px;
    }

    .location-content {
      max-width: 100%;
    }

    .location-h2 {
      font-size: var(--text-xl);
    }
  }
</style>
