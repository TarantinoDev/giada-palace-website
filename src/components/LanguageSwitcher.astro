---
import { languages, type Lang } from '../i18n/ui';
import { getPathWithLang, useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
---

<nav class="lang-switcher" aria-label={t('lang.label')}>
  <ul>
    {Object.entries(languages).map(([code, name]) => (
      <li>
        <a
          href={getPathWithLang(currentPath, code as Lang)}
          hreflang={code}
          aria-label={name}
          class:list={['lang-link', { 'is-active': code === lang }]}
          aria-current={code === lang ? 'true' : undefined}
        >
          {code.toUpperCase()}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .lang-switcher ul {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: 0;
  }

  .lang-link {
    display: block;
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: 0.06em;
    color: var(--gp-muted);
    text-decoration: none;
    padding: 3px 5px;
    border-radius: var(--radius-sm);
    transition: color 0.15s ease, background-color 0.15s ease;
    line-height: 1;
  }

  .lang-link:hover {
    color: var(--gp-ink);
  }

  .lang-link.is-active {
    color: var(--gp-navy);
    background-color: var(--gp-border-soft);
  }
</style>
