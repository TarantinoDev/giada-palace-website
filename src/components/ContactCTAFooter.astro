---
const waNumber  = import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '393513295448';
const waLink    = `https://wa.me/${waNumber}?text=Ciao%2C%20vorrei%20informazioni%20su%20Giada%20Palace`;
const phone     = import.meta.env.PUBLIC_PHONE_DISPLAY  ?? '+39 351 329 5448';
const phoneHref = import.meta.env.PUBLIC_PHONE_NUMBER   ?? '+393513295448';
---

<section class="cta-section" aria-label="Prenota il tuo soggiorno">
  <div class="container cta-inner">

    <div class="cta-text">
      <span class="eyebrow cta-eyebrow">— Contattaci —</span>
      <h2 class="cta-h2">Prenota il tuo soggiorno</h2>
      <p class="cta-body">
        Raccontaci date, numero di ospiti e preferenze.
        Ti risponderemo entro 24 ore con una proposta dedicata.
      </p>
    </div>

    <div class="cta-actions">
      <a href="/contatti" class="btn btn-primary">
        Invia richiesta
      </a>
      <a href={waLink} class="btn cta-wa" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
        </svg>
        WhatsApp
      </a>
      <a href={`tel:${phoneHref}`} class="btn btn-ghost cta-phone">
        {phone}
      </a>
    </div>

  </div>
</section>

<style>
  .cta-section {
    padding-block: var(--space-20);
    background-color: var(--gp-navy);
    color: var(--gp-white);
  }

  .cta-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-16);
    align-items: center;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .cta-eyebrow {
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: calc(var(--space-2) * -1);
  }

  .cta-h2 {
    font-size: var(--text-2xl);
    color: var(--gp-white);
    line-height: var(--leading-tight);
  }

  .cta-body {
    font-size: var(--text-md);
    color: rgba(255, 255, 255, 0.72);
    line-height: var(--leading-normal);
    max-width: 52ch;
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: stretch;
    min-width: 220px;
  }

  .cta-actions .btn {
    justify-content: center;
    width: 100%;
  }

  /* WhatsApp button: green */
  .cta-wa {
    background-color: #25D366;
    color: var(--gp-white);
    border-color: #25D366;
    gap: var(--space-2);
  }

  .cta-wa:hover {
    background-color: #1ebe5c;
    border-color: #1ebe5c;
    color: var(--gp-white);
  }

  /* Phone button on navy: ghost with white border */
  .cta-phone {
    background: transparent;
    color: var(--gp-white);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .cta-phone:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.7);
    color: var(--gp-white);
  }

  @media (max-width: 767px) {
    .cta-inner {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .cta-h2 {
      font-size: var(--text-xl);
    }

    .cta-actions {
      min-width: unset;
      width: 100%;
    }
  }
</style>
